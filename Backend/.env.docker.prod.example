# PostgreSQL (nombre del servicio en docker-compose)
DATABASE_URL=postgresql://neotech:neotech123@postgres:5432/neotech

# Server
PORT=3000
NODE_ENV=production
SSL_ACTIVE=false
LOG_LEVEL=info

# Auth (cambiar por una clave segura de 64+ caracteres)
JWT_SECRET=your_jwt_secret_here_min_64_chars_random
JWT_EXPIRES_IN=24h
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mercado Pago (sandbox para pruebas)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxx
MP_WEBHOOK_SECRET=your_webhook_secret

# Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=your_email@gmail.com

# Alertas
OWNER_EMAIL=owner@gmail.com

# WhatsApp
WHATSAPP_OWNER_NUMBER=549XXXXXXXXX

# Docker dev helper (permite simulate en entorno Docker)
ALLOW_SIMULATE_DEV=true
