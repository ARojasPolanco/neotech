# DB
DATABASE_URL=postgresql://user:password@localhost:5432/neotech

# Server
PORT=3000
NODE_ENV=development
SSL_ACTIVE=false
LOG_LEVEL=debug

# Auth
JWT_SECRET=your_jwt_secret_here_min_64_chars_random
JWT_EXPIRES_IN=24h

# Auth Webhook (usado internamente)
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Cloudinary (panel admin)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# WhatsApp link
WHATSAPP_OWNER_NUMBER=

# Mail
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Alertas
OWNER_EMAIL=
