# DB
DATABASE_URL=postgresql://user:password@localhost:5432/neotech

# Server
PORT=3000
NODE_ENV=development
SSL_ACTIVE=false
LOG_LEVEL=debug

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Auth Webhook (usado internamente)
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Cloudinary (panel admin - Fase 6)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mercado Pago (Fase 4)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# WhatsApp Cloud API (Fase 5)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OWNER_NUMBER=
WHATSAPP_VERIFY_TOKEN=

# Mail (Fase 5)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
